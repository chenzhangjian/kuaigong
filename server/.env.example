# 服务器配置
PORT=9091
NODE_ENV=development

# JWT密钥（生产环境必须设置）
# 使用以下命令生成安全密钥：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=quick-work-secret-key-2024
ADMIN_JWT_SECRET=admin-secret-key-2024

# 数据库配置（Supabase）
DATABASE_URL=your_supabase_database_url

# 高德地图API密钥
# 申请地址：https://lbs.amap.com/api/webservice/guide/create-project/get-key
AMAP_KEY=your_amap_api_key_here

# 阿里云短信配置（可选）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
