# 阿里云短信配置（请填写你的配置）

SMS_PROVIDER=aliyun

# 阿里云 AccessKey ID（从阿里云 AccessKey 管理获取）
ALIYUN_ACCESS_KEY_ID=你的AccessKeyID

# 阿里云 AccessKey Secret（从阿里云 AccessKey 管理获取）
ALIYUN_ACCESS_KEY_SECRET=你的AccessKeySecret

# 短信签名名称（必须与阿里云审核通过的签名完全一致）
ALIYUN_SMS_SIGN_NAME=快工

# 验证码模板CODE（从阿里云短信模板获取，如 SMS_xxxxxxxxx）
ALIYUN_SMS_TEMPLATE_CODE=SMS_你的模板CODE
